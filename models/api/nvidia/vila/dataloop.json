{
  "name": "nim-api-vila-demo",
  "displayName": "vila-demo",
  "version": "0.3.15",
  "scope": "project",
  "description": "NVIDIA Vila is a leading vision language model (VLMs) that enables the ability to query and summarize images and video from the physical or virtual world.",
  "attributes": {
    "Hub": [
      "NVIDIA",
      "Dataloop"
    ],
    "Provider": "NVIDIA",
    "Deployed By": "NVIDIA",
    "Category": [
      "Model",
      "NIM"
    ],
    "Gen AI": "LMM",
    "Media Type": [
      "Multi Modal"
    ]
  },
  "components": {
    "computeConfigs": [
      {
        "name": "nim-api-deploy",
        "runtime": {
          "podType": "regular-xs",
          "concurrency": 1,
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/cpu/nim-api:0.1.10",
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2
          }
        }
      }
    ],
    "modules": [
      {
        "name": "nim-api-module",
        "entryPoint": "models/api/main_api_adapter.py",
        "className": "ModelAdapter",
        "computeConfig": "nim-api-deploy",
        "description": "Vila NIM API Adapter for summarizing images and videos (.jpg, .jpeg, .png, .mp4).",
        "integrations": [
          "dl-ngc-api-key"
        ],
        "initInputs": [
          {
            "type": "Model",
            "name": "model_entity"
          }
        ],
        "functions": [
          {
            "name": "predict_items",
            "input": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "List of items to run inference on"
              }
            ],
            "output": [
              {
                "type": "Item[]",
                "name": "items",
                "description": "The same input images for prediction."
              },
              {
                "type": "Annotation[]",
                "name": "annotations",
                "description": "The predicted annotations."
              }
            ],
            "displayName": "Predict Items",
            "displayIcon": "",
            "description": "NIM API vila predict items"
          }
        ]
      },
      {
        "name": "video_to_prompt",
        "entryPoint": "models/api/nvidia/vila/main.py",
        "className": "VideoToPrompt",
        "initInputs": [],
        "functions": [
          {
            "name": "convert_video_to_prompt",
            "input": [
              {
                "type": "Item",
                "name": "item"
              }
            ],
            "output": [
              {
                "type": "Item",
                "name": "new_item"
              }
            ],
            "displayName": "Convert Video to Prompt Item",
            "displayIcon": "icon-dl-conversation",
            "description": "Converts a video item into a link in prompt item for processing."
          }
        ],
        "computeConfig": "nim-api-deploy",
        "description": "Pipeline node for converting video items into prompt items with video link.",
        "integrations": []
      }
    ],
    "models": [
      {
        "name": "vila-demo",
        "moduleName": "nim-api-module",
        "scope": "project",
        "status": "pre-trained",
        "inputType": "video",
        "outputType": "text",
        "configuration": {
          "nim_model_name": "nvidia/vila",
          "nim_invoke_url": "vlm/nvidia/vila",
          "max_tokens": 1024,
          "temperature": 0.20,
          "top_p": 0.70,
          "seed": 50,
          "stream": false
        },
        "description": "NVIDIA Vila is a leading vision language model (VLMs) that enables the ability to query and summarize images and video from the physical or virtual world."
      }
    ],
    "pipelineNodes": [
      {
        "invoke": {
          "type": "function",
          "namespace": "video_to_prompt.convert_video_to_prompt"
        },
        "name": "Convert Video Item to Prompt Item",
        "displayName": "Convert Video Item to Prompt Item",
        "description": "Converts a video item into a prompt item for processing.",
        "categories": ["Prompt Item Tools"],
        "scope": "node",
        "configuration": {
          "fields": [
            {
              "name": "name",
              "title": "Node Name",
              "props": {
                "title": true,
                "type": "string",
                "default": "Create Prompt Item for Video",
                "required": true,
                "placeholder": "Insert node name"
              },
              "rules": [
                {
                  "type": "required",
                  "effect": "error"
                }
              ],
              "widget": "dl-input"
            },
            {
              "name": "prompt_text",
              "title": "Prompt Context",
              "props": {
                "title": true,
                "type": "string",
                "default": "Describe what is happening in the video below.\n\n",
                "required": false,
                "placeholder": "Context string to be used around the input that will be turned into prompt"
              },
              "rules": [],
              "widget": "dl-input"
            },
            {
              "name": "prefix",
              "title": "Prefix",
              "props": {
                "title": true,
                "type": "string",
                "default": "prompt-",
                "required": false,
                "placeholder": "Prefix to the prompt item name"
              },
              "rules": [],
              "widget": "dl-input"
            },
            {
              "name": "directory",
              "title": "Directory",
              "props": {
                "title": true,
                "type": "string",
                "default": "/.dataloop/prompts",
                "required": false,
                "placeholder": "Directory where prompt item will be saved."
              },
              "rules": [],
              "widget": "dl-input"
            }
          ]
        }
      }
    ]
  }
} 