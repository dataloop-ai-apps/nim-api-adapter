{
  "displayName": "Audio Transcript (Parakeet CTC 0.6B ASR)",
  "name": "parakeet-ctc-0-6b-asr",
  "description": "Audio transcription pipeline node using NVIDIA Parakeet CTC 0.6B ASR. Transcribes audio items and uploads the resulting text files.",
  "version": "0.3.56",
  "attributes": {
    "Provider": "NVIDIA",
    "Category": "Application",
    "Media Type": [
      "Audio"
    ],
    "Application Type": [
      "Pipeline Node"
    ]
  },
  "codebase": {
    "type": "git",
    "gitUrl": "https://github.com/dataloop-ai-apps/nim-api-adapter",
    "gitTag": "0.3.56"
  },
  "scope": "public",
  "components": {
    "pipelineNodes": [
      {
        "scope": "node",
        "name": "audio-transcript",
        "displayName": "Audio Transcript",
        "description": "Transcribe audio files using NVIDIA Riva ASR and upload the text output.",
        "invoke": {
          "type": "function",
          "namespace": "riva-asr.riva-asr.audio_transcript"
        },
        "categories": [
          "audio-utils"
        ],
        "configuration": {
          "fields": [
            {
              "name": "output_dir",
              "title": "Output Directory",
              "props": {
                "title": true,
                "type": "string",
                "default": "",
                "required": false,
                "placeholder": "Remote directory for transcript upload (leave empty to use the audio item's directory)"
              },
              "rules": [],
              "widget": "dl-input"
            }
          ]
        }
      }
    ],
    "modules": [
      {
        "name": "riva-asr",
        "entryPoint": "nodes/parakeet_ctc_0_6b_asr/audio_transcript.py",
        "className": "ServiceRunner",
        "initInputs": [],
        "functions": [
          {
            "name": "audio_transcript",
            "description": "Transcribe an audio item using NVIDIA Riva ASR",
            "input": [
              {
                "type": "Item",
                "name": "item"
              }
            ],
            "output": [
              {
                "type": "Item",
                "name": "item"
              }
            ],
            "displayIcon": "icon-dl-audio-transcription",
            "displayName": "Audio Transcript"
          }
        ],
        "integrations": [
          "dl-ngc-api-key"
        ]
      }
    ],
    "services": [
      {
        "name": "riva-asr",
        "moduleName": "riva-asr",
        "runtime": {
          "podType": "regular-xs",
          "runnerImage": "gcr.io/viewo-g/piper/agent/runner/apps/audio_transcript:0.0.1",
          "numReplicas": 1,
          "concurrency": 10,
          "autoscaler": {
            "type": "rabbitmq",
            "minReplicas": 0,
            "maxReplicas": 2,
            "queueLength": 10
          }
        },
        "maxAttempts": 3,
        "executionTimeout": 172800,
        "drainTime": 600,
        "onReset": "failed",
        "runExecutionAsProcess": false,
        "operation": "none"
      }
    ]
  }
}
